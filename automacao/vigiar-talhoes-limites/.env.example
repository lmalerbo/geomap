# Copie pra ".env" (nunca commitar o .env de verdade) e preencha.

# Pasta de rede onde a exportação FME deixa os shapefiles (ver README.md).
# No Windows, use o caminho do drive mapeado (ex: I:\Projetos\SHAPES_RPA)
# ou o caminho UNC direto (\\lnxfs3\work3\Projetos\SHAPES_RPA).
PASTA_MONITORADA=I:\Projetos\SHAPES_RPA

# URL da API do GeoMap em produção (sem barra no final).
GEOMAP_API_URL=https://geomap-docker.onrender.com

# Conta de serviço dedicada (papel admin) — NUNCA a conta pessoal de um
# admin humano. Criar em Gerenciar Usuários antes de rodar isso.
GEOMAP_EMAIL=automacao@geoportal.local
GEOMAP_SENHA=

# Quanto tempo esperar sem nenhum evento novo na pasta antes de assumir
# que o conjunto de arquivos (.shp/.shx/.dbf/.prj/.cpg) terminou de
# chegar (ms). 60000 = 1 minuto.
DEBOUNCE_MS=60000
