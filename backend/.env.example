DATABASE_URL=postgres://geoportal:geoportal@localhost:5432/geoportal_dev
JWT_SECRET=troque-por-um-valor-aleatorio-longo
PORT=3000

# "true" em produção (Neon exige SSL); deixar vazio/ausente contra um
# Postgres local de dev, que não usa SSL.
PGSSL=

# Arquivos publicados (.pmtiles) vivem no Cloudflare R2 (compatível com a
# API S3), não em disco local — um host free-tier (ex: Render) não garante
# disco persistente entre deploys/restarts. Criar um bucket no R2 e um API
# token (Access Key ID + Secret) com permissão só nesse bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Conversão de .shp -> .pmtiles no upload de camada (POST/PUT /admin/camadas).
# Sem essas variáveis, o código tenta rodar "ogr2ogr"/"tippecanoe" direto do
# PATH (funciona out-of-the-box dentro da imagem Docker de produção —
# ver backend/Dockerfile — que já instala os dois). No Windows local,
# tippecanoe não compila nativamente — usa os binários Cygwin-compilados e
# aponta o PATH do processo filho pra pasta com as DLLs do Cygwin
# (cygwin1.dll etc), senão os .exe não sobem.
OGR2OGR_PATH=C:\Users\lmalerbo\cygwin-portable\root\bin\ogr2ogr.exe
TIPPECANOE_PATH=C:\Users\lmalerbo\tippecanoe\tippecanoe.exe
CYGWIN_BIN_DIR=C:\Users\lmalerbo\cygwin-portable\root\bin

# Geração automática de rótulos (número do talhão / nome da fazenda) pra
# camadas com os campos TALHAO+SECAO ou DESC_SECAO (ver
# pipeline/rotulos/README.md) — roda depois da conversão de geometria
# acima. Mesmo padrão de PATH das duas variáveis acima: sem elas, assume
# "python3"/"tile-join" já no PATH (caso normal dentro da imagem Docker).
# No Windows local, aponte pro python3/tile-join compilados via Cygwin —
# tile-join.exe sai do mesmo `make install` que já gera o tippecanoe.exe.
PYTHON_PATH=
TILEJOIN_PATH=
# Só precisa mexer se a estrutura de pastas divergir do padrão (backend/
# e pipeline/rotulos/ como irmãos na raiz do repo, ver backend/Dockerfile).
ROTULOS_SCRIPTS_DIR=
